# =====================================================================
# MESH Cloud — Proxmox deployment config
# Copy to cluster.env and edit. EVERY script reads this one file.
#   cp cluster.env.example cluster.env && nano cluster.env
# =====================================================================

# ---- Your domain (wildcard DNS *.DOMAIN must point at the EDGE public IP) ----
DOMAIN="meshcloud.example"
ACME_EMAIL="you@example.com"           # Let's Encrypt registration email

# ---- Wildcard TLS via DNS-01 (recommended). Cloudflare shown; blank = skip ----
# Create a scoped API token (Zone:DNS:Edit) at your DNS provider.
CLOUDFLARE_API_TOKEN=""                # leave "" to use a non-wildcard test cert

# ---- App source ----
REPO_URL="https://github.com/ch-acha/proxmox.git"
REPO_BRANCH="main"
APP_SUBDIR="."                        # app path inside the repo ("." = repo root)

# =====================================================================
#  PROXMOX HOST settings (used only by 00-host-create-vms.sh)
# =====================================================================
PVE_STORAGE="local-lvm"                # where VM disks live (pvesm status)
PVE_SNIPPETS_STORAGE="local"           # storage with the "snippets" content type
PVE_BRIDGE="vmbr0"                     # network bridge for the VMs
DEBIAN_IMAGE_URL="https://cloud.debian.org/images/cloud/bookworm/latest/debian-12-genericcloud-amd64.qcow2"

# VM IDs (must be free in your cluster)
VMID_EDGE=9101
VMID_HUB=9102
VMID_DATA=9103

# VM sizing
EDGE_CORES=2; EDGE_RAM=2048; EDGE_DISK=20
HUB_CORES=2;  HUB_RAM=2048;  HUB_DISK=20
DATA_CORES=2; DATA_RAM=4096; DATA_DISK=40

# Cloud-init login seeded into every VM (key-only is best; password is fallback)
VM_USER="mesh"
VM_SSH_PUBKEY=""                       # paste your ~/.ssh/id_*.pub  (strongly recommended)
VM_PASSWORD="changeme-now"             # used if no SSH key given

# =====================================================================
#  NETWORK / IP PLAN
#  Give each VM a STATIC private IP on your LAN bridge. The EDGE also needs
#  to be reachable from the internet (public IP, or router port-forward
#  80/443 tcp + 51820 udp -> EDGE_LAN_IP).
# =====================================================================
GATEWAY="192.168.1.1"                  # your LAN gateway
EDGE_IP="192.168.1.101"                # public-facing web node
HUB_IP="192.168.1.102"                 # WireGuard + FreeRADIUS
DATA_IP="192.168.1.103"                # MariaDB
NETMASK_CIDR="24"

# The EDGE's public endpoint that customer phones hit (DNS A record target).
# If behind NAT, this is your router's WAN IP; if public, == EDGE_IP.
EDGE_PUBLIC_IP="203.0.113.10"

# Public host:port that tenant ROUTERS dial for the WireGuard tunnel.
# If behind NAT, forward UDP 51820 -> HUB_IP and put your WAN IP here.
WG_PUBLIC_ENDPOINT="203.0.113.10:51820"

# ---- WireGuard overlay (tunnels + RADIUS live here; don't overlap your LAN) ----
WG_PORT=51820
WG_SUBNET="10.66.0.0/16"
WG_HUB_TUNNEL_IP="10.66.0.1"           # FreeRADIUS binds here

# =====================================================================
#  DATABASE (set strong values!)
# =====================================================================
DB_NAME="meshcloud"
DB_APP_USER="meshcloud"
DB_APP_PASS="CHANGE_ME_app"            # app (full rights on meshcloud)
DB_RADIUS_USER="meshradius"
DB_RADIUS_PASS="CHANGE_ME_radius"      # FreeRADIUS (CRUD on meshcloud)
DB_ROOT_PASS="CHANGE_ME_root"          # MariaDB root

# First platform superadmin (created in the DB at install time)
SUPERADMIN_USER="root"
SUPERADMIN_PASS="CHANGE_ME_super"
