# =====================================================================
# MESH Cloud — LAB (offline / LAN) config
# Single VM running everything. Plain HTTP, tenants via ?tenant=<slug>.
# M-Pesa is KEPT: the STK push is real; expose the callback with ngrok
# (see LAB.md). Copy to lab.env and edit.
#   cp lab.env.example lab.env && nano lab.env
# =====================================================================

# The lab VM's LAN IP (the one VM that runs MariaDB+WG+RADIUS+web).
LAB_IP="192.168.1.50"

# App source
REPO_URL="https://github.com/ch-acha/proxmox.git"
REPO_BRANCH="main"
APP_SUBDIR="."                        # app path inside the repo ("." = repo root)

# ---- WireGuard overlay (routers dial the lab VM over the LAN) ----
WG_PORT=51820
WG_SUBNET="10.66.0.0/16"
WG_HUB_TUNNEL_IP="10.66.0.1"          # FreeRADIUS binds here
# What the routers dial. On a LAN this is just the lab VM's LAN IP:port.
WG_PUBLIC_ENDPOINT="192.168.1.50:51820"

# ---- Database (lab defaults are fine; change if you like) ----
DB_NAME="meshcloud"
DB_APP_USER="meshcloud"
DB_APP_PASS="labapppass"
DB_RADIUS_USER="meshradius"
DB_RADIUS_PASS="labradiuspass"
DB_ROOT_PASS="labrootpass"

# First superadmin (operator console login)
SUPERADMIN_USER="root"
SUPERADMIN_PASS="labadmin123"

# ---- M-Pesa callback tunnel (optional but recommended for real payments) ----
# Run:  ngrok http http://${LAB_IP}    and paste the https URL here, e.g.
#   https://ab12cd34.ngrok-free.app
# Then set each tenant's "Callback base URL" in their admin Settings to this.
# Leave blank if you'll only use the offline simulator (simulate_payment.php).
NGROK_PUBLIC_URL=""
